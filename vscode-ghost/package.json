{
  "name": "ghost",
  "displayName": "Ghost",
  "description": "Memory-first personal assistant with persistent context, voice input, and agentic tool use",
  "version": "0.2.0",
  "publisher": "wcatz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wcatz/ghost"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "ai",
    "assistant",
    "memory",
    "claude",
    "voice",
    "chat"
  ],
  "icon": "assets/ghost.png",
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ghost",
          "title": "Ghost",
          "icon": "media/ghost-icon.svg"
        }
      ]
    },
    "views": {
      "ghost": [
        {
          "type": "webview",
          "id": "ghost.chat",
          "name": "Chat"
        },
        {
          "type": "webview",
          "id": "ghost.memories",
          "name": "Memories"
        }
      ]
    },
    "commands": [
      {
        "command": "ghost.sendMessage",
        "title": "Ghost: Send Message"
      },
      {
        "command": "ghost.newSession",
        "title": "Ghost: New Session"
      },
      {
        "command": "ghost.setMode",
        "title": "Ghost: Set Mode"
      },
      {
        "command": "ghost.searchMemories",
        "title": "Ghost: Search Memories"
      },
      {
        "command": "ghost.showChat",
        "title": "Ghost: Show Chat"
      },
      {
        "command": "ghost.openEditor",
        "title": "Ghost: Open Chat in Editor"
      }
    ],
    "keybindings": [
      {
        "command": "ghost.openEditor",
        "key": "alt+g",
        "mac": "alt+g"
      }
    ],
    "configuration": {
      "title": "Ghost",
      "properties": {
        "ghost.serverUrl": {
          "type": "string",
          "default": "http://127.0.0.1:2187",
          "description": "URL of the ghost serve daemon"
        },
        "ghost.authToken": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "Bearer token for ghost API authentication"
        },
        "ghost.autoStart": {
          "type": "boolean",
          "default": false,
          "description": "Automatically start ghost serve if not running"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "lint": "eslint src/",
    "test": "vitest run"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "marked": "^15.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.24.0",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.1",
    "vitest": "^3.0.0"
  }
}
