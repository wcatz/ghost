# Staleness scenarios v1. Each line: a fact that was updated over time.
# versions are ordered oldest -> newest (the LAST version is the live truth);
# age_days backdates created_at. probes query the fact two ways:
#   state   — neutral phrasing ("what X is it now")
#   premise — presupposes the OUTDATED state (the trap that makes agents
#             confidently wrong; modeled on STALE's Premise Resistance probe)
# A probe passes when search ranks the newest version above every older one.
# See docs/benchmarks.md ("Phase 3").
{"name":"postgres_version","versions":[{"content":"Production database runs Postgres 14 on the db-primary host.","age_days":180},{"content":"Production database migrated to Postgres 16 on db-primary; the Postgres 14 cluster is decommissioned.","age_days":20}],"probes":[{"type":"state","text":"what postgres version does the production database run"},{"type":"premise","text":"is production still running postgres 14"}]}
{"name":"deploy_tool","versions":[{"content":"Deployments run through Jenkins pipelines on the ci-jenkins host.","age_days":300},{"content":"Deployments moved from Jenkins to GitHub Actions; the Jenkins host is retired.","age_days":30}],"probes":[{"type":"state","text":"how do we deploy to production"},{"type":"premise","text":"which Jenkins pipeline deploys production"}]}
{"name":"rate_limit","versions":[{"content":"The public API rate limit is 100 requests per second per key.","age_days":150},{"content":"The public API rate limit was raised from 100 to 500 requests per second per key.","age_days":10}],"probes":[{"type":"state","text":"what is the API rate limit"},{"type":"premise","text":"why is the API limited to 100 requests per second"}]}
{"name":"default_branch","versions":[{"content":"The repository default branch is master.","age_days":400},{"content":"The repository default branch was renamed from master to main.","age_days":60}],"probes":[{"type":"state","text":"what is the default branch of the repo"},{"type":"premise","text":"how do I push to the master branch"}]}
{"name":"node_ip","versions":[{"content":"The k3s-mini node has IP address 192.168.9.150 on the lab network.","age_days":200},{"content":"The k3s-mini node was re-addressed to 192.168.9.203 after the lab network renumbering.","age_days":15}],"probes":[{"type":"state","text":"what is the IP address of the k3s-mini node"},{"type":"premise","text":"can I ssh to k3s-mini at 192.168.9.150"}]}
{"name":"go_version","versions":[{"content":"The project builds with Go 1.24.","age_days":250},{"content":"The project was upgraded to build with Go 1.26; Go 1.24 is no longer supported.","age_days":25}],"probes":[{"type":"state","text":"which Go version does the project build with"},{"type":"premise","text":"do we still support building with Go 1.24"}]}
{"name":"ssh_port","versions":[{"content":"The bastion host accepts SSH on port 22.","age_days":300},{"content":"The bastion host SSH port moved from 22 to 2222 after the security review.","age_days":40}],"probes":[{"type":"state","text":"what port does the bastion accept ssh on"},{"type":"premise","text":"ssh to the bastion on port 22 times out, why"}]}
{"name":"registry_move","versions":[{"content":"Container images are pushed to Docker Hub under the acme organization.","age_days":220},{"content":"Container images moved from Docker Hub to GitHub Container Registry ghcr.io/acme.","age_days":35}],"probes":[{"type":"state","text":"where do we push container images"},{"type":"premise","text":"what are the Docker Hub credentials for pushing images"}]}
{"name":"oncall_rotation","versions":[{"content":"On-call rotation is weekly, handed over every Monday at 09:00 UTC.","age_days":170},{"content":"On-call rotation changed to biweekly, handed over every other Wednesday at 12:00 UTC.","age_days":12}],"probes":[{"type":"state","text":"how does the on-call rotation work"},{"type":"premise","text":"who takes over on-call this Monday morning"}]}
{"name":"backup_schedule","versions":[{"content":"Database backups run nightly at 02:00 with 7-day retention.","age_days":190},{"content":"Database backups now run every six hours with 30-day retention.","age_days":18}],"probes":[{"type":"state","text":"what is the database backup schedule"},{"type":"premise","text":"is the nightly 2am backup window still causing load spikes"}]}
{"name":"tls_provider","versions":[{"content":"TLS certificates come from a paid DigiCert wildcard certificate renewed yearly.","age_days":365},{"content":"TLS certificates switched to Let's Encrypt with automatic renewal via cert-manager.","age_days":45}],"probes":[{"type":"state","text":"where do our TLS certificates come from"},{"type":"premise","text":"when does the DigiCert wildcard certificate expire"}]}
{"name":"feature_flag","versions":[{"content":"The new-billing feature flag is enabled only for internal test accounts.","age_days":90},{"content":"The new-billing feature flag was rolled out to all accounts and the old billing path is removed.","age_days":7}],"probes":[{"type":"state","text":"who has the new-billing feature flag enabled"},{"type":"premise","text":"how do internal test accounts opt into new-billing"}]}
{"name":"monitoring_tool","versions":[{"content":"Cluster metrics are collected by a hand-rolled StatsD and Graphite stack.","age_days":500},{"content":"Cluster monitoring migrated from StatsD/Graphite to kube-prometheus-stack.","age_days":50}],"probes":[{"type":"state","text":"what collects cluster metrics"},{"type":"premise","text":"which Graphite dashboard shows cluster metrics"}]}
