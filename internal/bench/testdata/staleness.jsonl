{"name":"lb_algorithm","versions":[{"content":"The load balancer uses round-robin across the API pods.","age_days":140},{"content":"The load balancer switched from round-robin to least-connections after the latency incident.","age_days":9}],"probes":[{"type":"state","text":"what load balancing algorithm does the API use"},{"type":"premise","text":"is round-robin causing the uneven API pod load"}]}
{"name":"ticket_system","versions":[{"content":"Bugs are tracked in Jira under the OPS project.","age_days":320},{"content":"Bug tracking moved from Jira to GitHub Issues; the Jira OPS project is read-only.","age_days":28}],"probes":[{"type":"state","text":"where do we track bugs"},{"type":"premise","text":"file this bug in the Jira OPS project"}]}
{"name":"api_endpoint","versions":[{"content":"Clients call the REST endpoint /api/v1/orders for order data.","age_days":260},{"content":"The orders endpoint moved to /api/v2/orders; /api/v1/orders returns 410 Gone.","age_days":14}],"probes":[{"type":"state","text":"which endpoint returns order data"},{"type":"premise","text":"why does /api/v1/orders return an error"}]}
{"name":"runner_size","versions":[{"content":"CI runners are 2-vCPU spot instances.","age_days":110},{"content":"CI runners were upgraded to 8-vCPU dedicated instances to fix flaky timeouts.","age_days":6}],"probes":[{"type":"state","text":"what size are the CI runners"},{"type":"premise","text":"are the 2-vCPU runners causing CI timeouts"}]}
{"name":"k8s_chain","versions":[{"content":"The cluster runs Kubernetes 1.27.","age_days":300},{"content":"The cluster was upgraded from Kubernetes 1.27 to 1.29.","age_days":120},{"content":"The cluster now runs Kubernetes 1.31 after the latest upgrade from 1.29.","age_days":10}],"probes":[{"type":"state","text":"what kubernetes version does the cluster run"},{"type":"premise","text":"are we still on kubernetes 1.27"}]}
{"name":"ntp_chain","versions":[{"content":"Hosts sync time against pool.ntp.org.","age_days":400},{"content":"Hosts switched from pool.ntp.org to the internal ntp1.corp time server.","age_days":150},{"content":"Time sync moved to chrony against ntp2.corp after ntp1.corp was decommissioned.","age_days":21}],"probes":[{"type":"state","text":"which time server do hosts sync against"},{"type":"premise","text":"is ntp1.corp still serving time"}]}
{"name":"secrets_chain","versions":[{"content":"Secrets are stored as plain Kubernetes secrets in the cluster.","age_days":450},{"content":"Secrets moved from plain Kubernetes secrets to sealed-secrets.","age_days":200},{"content":"Secrets management moved from sealed-secrets to SOPS with Age encryption in the infra repo.","age_days":30}],"probes":[{"type":"state","text":"how are secrets managed"},{"type":"premise","text":"how do I add a sealed-secret to the cluster"}]}
{"name":"domain_migration","versions":[{"content":"The status page is served at status.acme.io.","age_days":210},{"content":"The status page moved from status.acme.io to status.acme.com during the domain consolidation.","age_days":16}],"probes":[{"type":"state","text":"what is the status page URL"},{"type":"premise","text":"status.acme.io is not resolving, is it down"}]}
{"name":"python_runtime","versions":[{"content":"Lambda functions run on the Python 3.9 runtime.","age_days":280},{"content":"Lambda functions were upgraded to the Python 3.12 runtime; 3.9 is deprecated.","age_days":19}],"probes":[{"type":"state","text":"which python runtime do the lambda functions use"},{"type":"premise","text":"deploy this function to the python 3.9 runtime"}]}
{"name":"vpn_solution","versions":[{"content":"Remote access uses OpenVPN with certificates issued per laptop.","age_days":380},{"content":"Remote access moved from OpenVPN to Tailscale; the OpenVPN server is gone.","age_days":42}],"probes":[{"type":"state","text":"how do I get remote access to the network"},{"type":"premise","text":"my OpenVPN certificate expired, how do I renew it"}]}
